#!/bin/bash
#SBATCH --account=biyik_1173
#SBATCH --partition=gpu
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --gpus-per-task=p100:1
#SBATCH --mem=32G
#SBATCH --time=6:00:00
#SBATCH --job-name=edm_fixed
#SBATCH --output=/project2/biyik_1165/abhajha/condBFNPol/jobs/logs/%x_%j.out
#SBATCH --error=/project2/biyik_1165/abhajha/condBFNPol/jobs/logs/%x_%j.err

# Retrain EDM with fixed loss function

source /apps/conda/miniforge3/24.11.3/etc/profile.d/conda.sh
conda activate bfn

cd /project2/biyik_1165/abhajha/condBFNPol

echo "=========================================="
echo "SLURM_JOB_ID = $SLURM_JOB_ID"
echo "SLURM_JOB_NODELIST = $SLURM_JOB_NODELIST"
echo "=========================================="

echo "Training EDM with fixed loss at $(date)"
python train.py --config-name=train_edm_lunar_lander

echo "Done at $(date)"
